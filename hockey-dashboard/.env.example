# Copy this file to .env and fill in your values
# Yahoo Developer Console: https://developer.yahoo.com/apps/

YAHOO_CLIENT_ID=your_client_id_here
YAHOO_CLIENT_SECRET=your_client_secret_here

# Must match the Redirect URI registered in your Yahoo app
REDIRECT_URI=http://localhost:5000/callback

# Random secret key for Flask session signing (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change_me_to_a_random_string
